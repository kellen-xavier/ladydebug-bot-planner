# Discord (obrigatório para rodar o bot)
DISCORD_TOKEN=

# Opcional: ID do app no Developer Portal. Usado para imprimir URL de convite em erros.
DISCORD_CLIENT_ID=

# Opcional para testes locais: sincroniza slash commands só neste servidor.
# Sem isso, o Discord pode demorar para propagar comandos globais.
DISCORD_GUILD_ID=

# Repositórios (v1)
GITHUB_TOKEN=
AZURE_DEVOPS_PAT=

# Banco (opcional; padrão: daily.db)
DB_PATH=daily.db

# Fase 1+: chave do LLM para o resumo factual dos links
# ANTHROPIC_API_KEY=
